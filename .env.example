# Server port
PORT=5000

# Allowed frontend origin (Vite dev server default shown; set to your deployed domain in prod)
CLIENT_ORIGIN=http://localhost:5173

# SMTP credentials (optional) — if left blank, messages are still saved to
# server/messages.json but no email is sent. Example uses Gmail SMTP with an
# App Password (not your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-app-password

# Where contact form messages should be emailed to
CONTACT_RECEIVER=karthikboddupally0@gmail.com
